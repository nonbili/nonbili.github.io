---
import '../styles/global.css'

const projects = [
  {
    icon: '/meron.png',
    title: 'Meron',
    description: 'Fast, secure email client with chat and kanban views',
    url: 'https://meron.im',
  },
  {
    icon: '/noutube.png',
    title: 'NouTube',
    description: 'YouTube and YouTube Music in a single app. No ads',
    url: 'https://github.com/nonbili/NouTube',
  },
  {
    icon: '/nora.png',
    title: 'Nora',
    description: 'Facebook, Instagram, Reddit, Threads and X in a single app. No ads',
    url: 'https://github.com/nonbili/Nora',
  },
  {
    icon: '/inks.png',
    title: 'Inks',
    description: 'Follow any websites, convert SNS to RSS',
    url: 'https://inks.page',
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>Nonbili</title>
  </head>
  <body>
    <div class="page-shell">
      <main class="project-list" aria-label="Nonbili projects">
        <header class="site-header">
          <p>Nonbili</p>
          <h1>Apps for daily joy</h1>
        </header>
        {
          projects.map((project) => (
            <a class="project-card" href={project.url} target="_blank" rel="noreferrer" aria-label={`${project.title}: ${project.description}`}>
              <img class="project-icon" src={project.icon} alt="" width="100" height="100" loading="eager" />
              <div class="project-copy">
                <h2>{project.title}</h2>
                <p>{project.description}</p>
              </div>
              <span class="project-arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </main>
    </div>
    <footer>© Nonbili Inc.</footer>
  </body>
</html>
